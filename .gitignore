# =============================================================================
# .gitignore — FakeBill Detector
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
*.so

# --- Environnements virtuels ---
venv/
env/
.env
.venv/
ENV/

# --- Variables d'environnement (JAMAIS committer) ---
.env
.env.local
.env.*.local
!.env.example
!.env.local.example

# --- Modèles ML (trop lourds pour Git) ---
backend/models/*.pkl

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- Next.js ---
frontend/.next/
frontend/out/
frontend/node_modules/
frontend/.vercel

# --- Node ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- VS Code ---
.vscode/
*.code-workspace

# --- Logs ---
*.log
logs/

# --- Coverage ---
htmlcov/
.coverage
coverage.xml